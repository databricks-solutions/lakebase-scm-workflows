{
  "name": "@databricks-solutions/lakebase-app-dev-kit",
  "version": "0.3.0-alpha.21",
  "description": "Lakebase-backed application development kit — shared scripts, agent skills (SCM today, TDD next), MCP server, and OpenAI Foundry tool spec. Consumed by lakebase-scm-extension and coding agents (Claude Code, Claude Desktop, OpenAI Codex, Cursor, Databricks Genie Code).",
  "type": "module",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/databricks-solutions/lakebase-app-dev-kit"
  },
  "main": "./dist/scripts/index.cjs",
  "module": "./dist/scripts/index.js",
  "types": "./dist/scripts/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/scripts/index.d.ts",
        "default": "./dist/scripts/index.js"
      },
      "require": {
        "types": "./dist/scripts/index.d.cts",
        "default": "./dist/scripts/index.cjs"
      }
    },
    "./github": {
      "import": {
        "types": "./dist/scripts/github/index.d.ts",
        "default": "./dist/scripts/github/index.js"
      },
      "require": {
        "types": "./dist/scripts/github/index.d.cts",
        "default": "./dist/scripts/github/index.cjs"
      }
    },
    "./lakebase": {
      "import": {
        "types": "./dist/scripts/lakebase/index.d.ts",
        "default": "./dist/scripts/lakebase/index.js"
      },
      "require": {
        "types": "./dist/scripts/lakebase/index.d.cts",
        "default": "./dist/scripts/lakebase/index.cjs"
      }
    },
    "./git": {
      "import": {
        "types": "./dist/scripts/git/index.d.ts",
        "default": "./dist/scripts/git/index.js"
      },
      "require": {
        "types": "./dist/scripts/git/index.d.cts",
        "default": "./dist/scripts/git/index.cjs"
      }
    },
    "./util": {
      "import": {
        "types": "./dist/scripts/util/index.d.ts",
        "default": "./dist/scripts/util/index.js"
      },
      "require": {
        "types": "./dist/scripts/util/index.d.cts",
        "default": "./dist/scripts/util/index.cjs"
      }
    }
  },
  "bin": {
    "lakebase-get-connection": "./dist/scripts/lakebase/get-connection.cli.js",
    "lakebase-schema-diff": "./dist/scripts/lakebase/schema-diff.cli.js",
    "lakebase-github-token": "./dist/scripts/github/auth.cli.js",
    "lakebase-create-project": "./dist/scripts/lakebase/create-project.cli.js",
    "lakebase-migrate": "./dist/scripts/lakebase/migrate.cli.js",
    "lakebase-cut-backup": "./dist/scripts/lakebase/cut-backup.cli.js",
    "lakebase-detect-language": "./dist/scripts/lakebase/detect-language.cli.js",
    "lakebase-mcp-server": "./dist/apps/mcp-server/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsx scripts/sync-devhub-skills.ts && npm run build && husky",
    "sync:devhub": "tsx scripts/sync-devhub-skills.ts",
    "check:devhub": "tsx scripts/sync-devhub-skills.ts --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "bash scripts/run-live-tests.sh"
  },
  "dependencies": {
    "@databricks/appkit": "*",
    "@databricks/lakebase": "*",
    "adm-zip": "^0.5.16",
    "find-java-home": "^2.0.0",
    "octokit": "^4.0.0",
    "pg": "^8.20.0",
    "tar": "^7.4.3",
    "tree-kill": "^1.2.2",
    "tweetsodium": "^0.0.5"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/tar": "^6.1.13",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
